{
  "name": "esp-partition-utils",
  "version": "0.1.0",
  "description": "ESP-IDF partition table encoder/decoder for Node.js and browsers",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alufers/esp-partition-utils-js.git"
  },
  "bin": {
    "esp-partition-table": "bin/esp-partition-table.cjs"
  },
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs",
      "types": "./dist/types/index.d.ts"
    }
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "npm run build:types && rolldown -c rolldown.config.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "parttool": "node ./bin/esp-partition-table.cjs",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --config jest.config.cjs",
    "lint": "oxlint --deny-warnings src test",
    "format": "oxfmt src test",
    "format:check": "oxfmt --check src test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.18",
    "jest": "^29.7.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^0.16.7",
    "rolldown": "^1.0.0-beta.9",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  }
}
